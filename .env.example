# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS headers.
# Use * to allow all origins (suitable for development; restrict in production).
# Example (production): https://execudashboard.vercel.app,https://www.execudashboard.com
ALLOWED_ORIGINS=*

# ─── PORT ────────────────────────────────────────────────────────────────────
# Railway automatically injects $PORT at runtime — do NOT set this variable
# manually in the Railway dashboard environment variables panel.
# For local development only:
PORT=8000
